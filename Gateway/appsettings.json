{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/users/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "Match": {
          "Path": "/products/{**catch-all}"
        }
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": {
          "Path": "/cart/{**catch-all}"
        }
      },
      "products-admin-route": {
        "ClusterId": "products-admin-cluster",
        "Match": {
          "Path": "/products/admin/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/products"
          }
        ]
      },
      "cart-admin-route": {
        "ClusterId": "cart-admin-cluster",
        "Match": {
          "Path": "/cart/admin/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/cart"
          }
        ]
      }
    },
    "Clusters": {
      "users-cluster": {
        "Destinations": {
          "users": {
            "Address": "http://user-service:8080/"
          }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://user-service:8080/"
          }
        }
      },
      "products-cluster": {
        "Destinations": {
          "products": {
            "Address": "http://product-service:8000/"
          }
        }
      },
      "products-admin-cluster": {
        "Destinations": {
          "products": {
            "Address": "http://product-service:8000/"
          }
        }
      },
      "cart-admin-cluster": {
        "Destinations": {
          "cart": {
            "Address": "http://cart-service:8000/"
          }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart": {
            "Address": "http://cart-service:8000/"
          }
        }
      }
    }
  }
}